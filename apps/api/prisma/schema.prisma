generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum DocumentType {
  CPF
  CNPJ
}

model Producer {
  id           String       @id @default(uuid())
  document     String       @unique
  documentType DocumentType
  name         String
  farms        Farm[]
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  deletedAt    DateTime?

  @@index([name])
}

model Farm {
  id             String        @id @default(uuid())
  producerId     String
  producer       Producer      @relation(fields: [producerId], references: [id], onDelete: Cascade)
  name           String
  city           String
  state          String
  totalArea      Decimal       @db.Decimal(12, 2)
  arableArea     Decimal       @db.Decimal(12, 2)
  vegetationArea Decimal       @db.Decimal(12, 2)
  harvestCrops   HarvestCrop[]
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  deletedAt      DateTime?

  @@index([producerId])
  @@index([state])
}

model HarvestCrop {
  id        String   @id @default(uuid())
  farmId    String
  farm      Farm     @relation(fields: [farmId], references: [id], onDelete: Cascade)
  harvest   String
  crop      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([farmId, harvest, crop])
  @@index([crop])
}
